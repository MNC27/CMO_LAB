import numpy as np
import matplotlib.pyplot as plt

# ---------------- SIMPLEX FUNCTION ----------------
def simplex(c, A, b):
    m, n = A.shape
    
    # Add slack variables
    I = np.eye(m)
    A = np.hstack((A, I))
    c = np.hstack((c, np.zeros(m)))
    
    B = list(range(n, n + m))  # slack variables
    N = list(range(n))
    
    while True:
        B_mat = A[:, B]
        xB = np.linalg.inv(B_mat) @ b
        
        cB = c[B]
        lambda_ = cB @ np.linalg.inv(B_mat)
        
        reduced_costs = []
        for j in N:
            rc = c[j] - lambda_ @ A[:, j]
            reduced_costs.append(rc)
        
        # Optimality check
        if all(rc <= 1e-6 for rc in reduced_costs):
            x = np.zeros(len(c))
            x[B] = xB
            return x[:n], c @ x
        
        # Entering variable
        entering_index = np.argmax(reduced_costs)
        entering = N[entering_index]
        
        d = np.linalg.inv(B_mat) @ A[:, entering]
        
        # Ratio test
        ratios = []
        for i in range(len(d)):
            if d[i] > 0:
                ratios.append(xB[i] / d[i])
            else:
                ratios.append(np.inf)
        
        leaving_index = np.argmin(ratios)
        
        if ratios[leaving_index] == np.inf:
            raise Exception("Unbounded")
        
        # Update
        B[leaving_index] = entering
        N[entering_index] = leaving_index


# ---------------- PROBLEM ----------------
c = np.array([3, 2])
A = np.array([[1, 1],
              [2, 1]])
b = np.array([4, 5])

solution, value = simplex(c, A, b)

print("Optimal Solution:", solution)
print("Optimal Value:", value)


# ---------------- PLOTTING ----------------
x = np.linspace(0, 5, 100)

# Constraints
y1 = 4 - x          # x1 + x2 = 4
y2 = 5 - 2*x        # 2x1 + x2 = 5

plt.figure(figsize=(6,6))

# Plot constraint lines
plt.plot(x, y1, label='x1 + x2 = 4')
plt.plot(x, y2, label='2x1 + x2 = 5')

# Feasible region shading
y = np.minimum(y1, y2)
y[y < 0] = 0
plt.fill_between(x, y, alpha=0.3)

# Plot optimal point
plt.scatter(solution[0], solution[1], color='red', zorder=5)
plt.text(solution[0], solution[1], ' Optimal', fontsize=12)

plt.xlim(0,5)
plt.ylim(0,5)
plt.xlabel('x1')
plt.ylabel('x2')
plt.title('Simplex Method - Feasible Region')
plt.legend()
plt.grid()

plt.show()
