import numpy as np
import matplotlib.pyplot as plt


class ConjugateGradient:
    def __init__(self, A, b, x0, tol=1e-6, max_iter=100):
        self.A = A
        self.b = b
        self.x = x0.astype(float)
        self.tol = tol
        self.max_iter = max_iter

        self.history = [self.x.copy()]

    def solve(self):
        r = self.b - self.A @ self.x   # residual
        d = r.copy()

        for _ in range(self.max_iter):
            if np.linalg.norm(r) < self.tol:
                break

            Ad = self.A @ d
            alpha = (r @ r) / (d @ Ad)

            self.x = self.x + alpha * d
            r_new = r - alpha * Ad

            beta = (r_new @ r_new) / (r @ r)
            d = r_new + beta * d

            r = r_new
            self.history.append(self.x.copy())

        return self.x


# ----------- Example Usage -----------

def quadratic_function(X, Y):
    return 0.5*(4*X**2 + 2*X*Y + 3*Y**2) - (1*X + 2*Y)


if __name__ == "__main__":
    # Define problem (A must be symmetric positive definite)
    A = np.array([[4, 1],
                  [1, 3]])
    b = np.array([1, 2])
    x0 = np.array([2.0, 2.0])

    # Solve
    cg = ConjugateGradient(A, b, x0)
    solution = cg.solve()

    print("Optimal Solution:", solution)

    # ----------- Plotting -----------
    path = np.array(cg.history)

    x_vals = np.linspace(-1, 2, 100)
    y_vals = np.linspace(-1, 2, 100)
    X, Y = np.meshgrid(x_vals, y_vals)
    Z = quadratic_function(X, Y)

    plt.contour(X, Y, Z, levels=20)
    plt.plot(path[:, 0], path[:, 1], 'ro-', label="CG Path")
    plt.title("Conjugate Gradient Method")
    plt.xlabel("x1")
    plt.ylabel("x2")
    plt.legend()
    plt.grid()
    plt.show()
