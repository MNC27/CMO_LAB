import numpy as np

# =========================================================
# OBJECTIVE FUNCTION
# Example: f(x1, x2) = (x1 - 1)^2 + (x2 - 2)^2
# =========================================================
def f(x):
    return (x[0] - 1)**2 + (x[1] - 2)**2


# =========================================================
# CONSTRAINTS
# Equality: h(x) = 0
# Inequality: g(x) <= 0
# =========================================================

def h(x):
    return np.array([
        x[0] - x[1]   # equality constraint
    ])

def g(x):
    return np.array([
        x[0] + x[1] - 2   # inequality constraint
    ])


# =========================================================
# NUMERICAL GRADIENT
# =========================================================
def numerical_gradient(func, x):
    grad = np.zeros_like(x)
    h_step = 1e-6

    for i in range(len(x)):
        x1 = x.copy()
        x1[i] += h_step
        grad[i] = (func(x1) - func(x)) / h_step

    return grad


# =========================================================
# BFGS OPTIMIZER (inner solver)
# =========================================================
def bfgs(func, x0, tol=1e-6, max_iter=200):
    n = len(x0)
    x = x0.copy()
    H = np.eye(n)

    for _ in range(max_iter):
        grad = numerical_gradient(func, x)

        if np.linalg.norm(grad) < tol:
            break

        d = -H @ grad

        # Backtracking line search
        alpha = 1.0
        rho = 0.5
        c = 1e-4

        while func(x + alpha * d) > func(x) + c * alpha * np.dot(grad, d):
            alpha *= rho

        x_new = x + alpha * d

        s = x_new - x
        y = numerical_gradient(func, x_new) - grad

        if np.dot(s, y) == 0:
            break

        rho_k = 1.0 / np.dot(y, s)
        I = np.eye(n)

        H = (I - rho_k * np.outer(s, y)) @ H @ (I - rho_k * np.outer(y, s)) \
            + rho_k * np.outer(s, s)

        x = x_new

    return x


# =========================================================
# AUGMENTED LAGRANGIAN FUNCTION
# =========================================================
def augmented_lagrangian(x, lam_h, lam_g, r):
    val = f(x)

    # Equality constraints
    h_val = h(x)
    val += np.dot(lam_h, h_val) + (r / 2) * np.sum(h_val**2)

    # Inequality constraints
    g_val = g(x)
    for i in range(len(g_val)):
        val += (1 / (2 * r)) * max(0, lam_g[i] + r * g_val[i])**2

    return val


# =========================================================
# AUGMENTED LAGRANGIAN METHOD
# =========================================================
def augmented_lagrangian_method(x0, tol=1e-6, max_outer=20):
    x = x0.copy()

    # Initialize multipliers
    lam_h = np.zeros(len(h(x)))
    lam_g = np.zeros(len(g(x)))

    r = 1.0

    for k in range(max_outer):

        # Minimize Augmented Lagrangian
        func = lambda x_var: augmented_lagrangian(x_var, lam_h, lam_g, r)
        x = bfgs(func, x)

        # Update multipliers
        h_val = h(x)
        g_val = g(x)

        lam_h = lam_h + r * h_val
        lam_g = np.maximum(0, lam_g + r * g_val)

        # Check convergence
        if np.linalg.norm(h_val) < tol and np.all(g_val <= tol):
            print(f"\nConverged at iteration {k+1}")
            break

        # Increase penalty moderately
        r *= 2

        print(f"Iter {k+1}: x={x}, f(x)={f(x)}, h={h_val}, g={g_val}")

    return x


# =========================================================
# MAIN EXECUTION
# =========================================================
if __name__ == "__main__":
    x0 = np.array([2.0, 0.0])  # initial guess

    solution = augmented_lagrangian_method(x0)

    print("\nOptimal Solution:", solution)
    print("Optimal Value:", f(solution))
