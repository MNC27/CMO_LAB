import math

# Objective function (example)
def f(x):
    return x**2 - 4*x + 4   # convex function (minimum at x = 2)

# Generate Fibonacci numbers
def fibonacci(n):
    fib = [1, 1]
    for i in range(2, n):
        fib.append(fib[i-1] + fib[i-2])
    return fib

def fibonacci_search(a, b, n):
    fib = fibonacci(n)
    
    # Initial points
    x1 = a + (fib[n-2] / fib[n-1]) * (b - a)
    x2 = a + (fib[n-1] / fib[n-1]) * (b - a)
    
    f1 = f(x1)
    f2 = f(x2)
    
    for k in range(1, n-1):
        if f1 > f2:
            a = x1
            x1 = x2
            f1 = f2
            
            x2 = a + (fib[n-k-1] / fib[n-k]) * (b - a)
            f2 = f(x2)
        else:
            b = x2
            x2 = x1
            f2 = f1
            
            x1 = a + (fib[n-k-2] / fib[n-k]) * (b - a)
            f1 = f(x1)
    
    # Final comparison
    return (a + b) / 2


# Example usage
a = 0
b = 5
n = 10  # number of iterations

minimum = fibonacci_search(a, b, n)
print("Approximate minimum at x =", minimum)
print("Function value =", f(minimum))
