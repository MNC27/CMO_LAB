import math
import matplotlib.pyplot as plt
import numpy as np

# Objective function
def f(x):
    return x**2 - 4*x + 4   # minimum at x = 2

# Fibonacci sequence
def fibonacci(n):
    fib = [1, 1]
    for i in range(2, n):
        fib.append(fib[i-1] + fib[i-2])
    return fib

def fibonacci_search_with_plot(a, b, n):
    fib = fibonacci(n)
    
    # Store intervals for plotting
    intervals = [(a, b)]
    
    x1 = a + (fib[n-2] / fib[n-1]) * (b - a)
    x2 = a + (fib[n-1] / fib[n-1]) * (b - a)
    
    f1 = f(x1)
    f2 = f(x2)
    
    for k in range(1, n-1):
        if f1 > f2:
            a = x1
            x1 = x2
            f1 = f2
            
            x2 = a + (fib[n-k-1] / fib[n-k]) * (b - a)
            f2 = f(x2)
        else:
            b = x2
            x2 = x1
            f2 = f1
            
            x1 = a + (fib[n-k-2] / fib[n-k]) * (b - a)
            f1 = f(x1)
        
        intervals.append((a, b))
    
    xmin = (a + b) / 2
    return xmin, intervals


# Parameters
a, b = 0, 5
n = 10

xmin, intervals = fibonacci_search_with_plot(a, b, n)

print("Minimum at x =", xmin)
print("f(x) =", f(xmin))


# 🔹 Plotting
x_vals = np.linspace(a, b, 400)
y_vals = f(x_vals)

plt.figure()
plt.plot(x_vals, y_vals)
plt.axvline(xmin)

# Plot shrinking intervals
for (l, r) in intervals:
    plt.axvline(l)
    plt.axvline(r)

plt.title("Fibonacci Search Method")
plt.xlabel("x")
plt.ylabel("f(x)")
plt.show()
