import numpy as np

# =========================================================
# OBJECTIVE FUNCTION
# Example: f(x1, x2) = (x1 - 1)^2 + (x2 - 2)^2
# =========================================================
def f(x):
    return (x[0] - 1)**2 + (x[1] - 2)**2


# =========================================================
# CONSTRAINTS
# g(x) <= 0  → inequality
# h(x) = 0   → equality (optional)
# =========================================================

def g(x):
    return np.array([
        x[0] + x[1] - 2   # example constraint
    ])

def h(x):
    return np.array([])   # no equality constraints here


# =========================================================
# NUMERICAL GRADIENT
# =========================================================
def numerical_gradient(func, x):
    grad = np.zeros_like(x)
    h_step = 1e-6
    
    for i in range(len(x)):
        x1 = x.copy()
        x1[i] += h_step
        grad[i] = (func(x1) - func(x)) / h_step
    
    return grad


# =========================================================
# BFGS OPTIMIZER
# =========================================================
def bfgs(func, x0, tol=1e-6, max_iter=200):
    n = len(x0)
    x = x0.copy()
    H = np.eye(n)

    for k in range(max_iter):
        grad = numerical_gradient(func, x)

        if np.linalg.norm(grad) < tol:
            break

        d = -H @ grad

        # Backtracking line search
        alpha = 1.0
        rho = 0.5
        c = 1e-4
        
        while func(x + alpha * d) > func(x) + c * alpha * np.dot(grad, d):
            alpha *= rho

        x_new = x + alpha * d

        s = x_new - x
        y = numerical_gradient(func, x_new) - grad

        if np.dot(s, y) == 0:
            break

        rho_k = 1.0 / np.dot(y, s)
        I = np.eye(n)

        H = (I - rho_k * np.outer(s, y)) @ H @ (I - rho_k * np.outer(y, s)) \
            + rho_k * np.outer(s, s)

        x = x_new

    return x


# =========================================================
# EXTERIOR PENALTY FUNCTION
# =========================================================
def exterior_penalty(x, r):
    penalty = 0
    
    # Inequality penalty
    for gi in g(x):
        penalty += max(0, gi)**2
    
    # Equality penalty
    for hi in h(x):
        penalty += hi**2

    return f(x) + r * penalty


# =========================================================
# INTERIOR (BARRIER) FUNCTION
# =========================================================
def interior_barrier(x, r):
    penalty = 0
    
    for gi in g(x):
        if gi >= 0:
            return np.inf  # outside feasible region
        penalty -= np.log(-gi)

    return f(x) + r * penalty


# =========================================================
# EXTERIOR PENALTY METHOD DRIVER
# =========================================================
def run_exterior_penalty(x0):
    print("\n--- EXTERIOR PENALTY METHOD ---")
    
    x = x0.copy()
    r = 1.0

    for i in range(6):
        func = lambda x_var: exterior_penalty(x_var, r)
        x = bfgs(func, x)

        print(f"Iteration {i+1}, r={r:.2e}, x={x}, f(x)={f(x)}")
        
        r *= 10  # increase penalty

    return x


# =========================================================
# INTERIOR PENALTY METHOD DRIVER
# =========================================================
def run_interior_penalty(x0):
    print("\n--- INTERIOR (BARRIER) METHOD ---")
    
    x = x0.copy()
    r = 1.0

    for i in range(6):
        func = lambda x_var: interior_barrier(x_var, r)
        x = bfgs(func, x)

        print(f"Iteration {i+1}, r={r:.2e}, x={x}, f(x)={f(x)}")
        
        r *= 0.1  # decrease barrier

    return x


# =========================================================
# MAIN EXECUTION
# =========================================================
if __name__ == "__main__":

    # Exterior: start OUTSIDE feasible region
    x0_ext = np.array([3.0, 3.0])
    sol_ext = run_exterior_penalty(x0_ext)

    print("\nFinal Exterior Solution:", sol_ext)
    print("Objective Value:", f(sol_ext))

    # Interior: start INSIDE feasible region
    x0_int = np.array([0.5, 0.5])
    sol_int = run_interior_penalty(x0_int)

    print("\nFinal Interior Solution:", sol_int)
    print("Objective Value:", f(sol_int))
