# ==========================================
# Marquardt (Levenberg-Marquardt) Method
# ==========================================

import numpy as np
import matplotlib.pyplot as plt

# ------------------------------------------
# Define Objective Function
# ------------------------------------------

def f(x):
    return x[0]**2 + x[1]**2 + 3*x[0]*x[1] + 4

# ------------------------------------------
# Gradient
# ------------------------------------------

def grad_f(x):
    return np.array([
        2*x[0] + 3*x[1],
        2*x[1] + 3*x[0]
    ])

# ------------------------------------------
# Hessian
# ------------------------------------------

def hessian_f(x):
    return np.array([
        [2, 3],
        [3, 2]
    ])

# ------------------------------------------
# Marquardt Algorithm
# ------------------------------------------

def marquardt_method(x0, lam=0.01, tol=1e-6, max_iter=100):
    
    x = np.array(x0, dtype=float)
    history = [x.copy()]
    
    print("Iteration | x1        x2        | f(x)       | lambda")
    print("------------------------------------------------------")
    
    for i in range(max_iter):
        grad = grad_f(x)
        H = hessian_f(x)
        
        # Modified Hessian
        H_mod = H + lam * np.eye(len(x))
        
        try:
            # Solve system
            p = np.linalg.solve(H_mod, grad)
        except np.linalg.LinAlgError:
            print("Hessian not invertible!")
            return x
        
        x_new = x - p
        
        print(f"{i+1:9d} | {x_new[0]:.6f} {x_new[1]:.6f} | {f(x_new):.6f} | {lam:.6f}")
        
        # Update lambda based on improvement
        if f(x_new) < f(x):
            lam /= 10   # move towards Newton
        else:
            lam *= 10   # move towards gradient descent
        
        history.append(x_new.copy())
        
        # Convergence check
        if np.linalg.norm(x_new - x) < tol:
            print("\nConverged!")
            return x_new, history
        
        x = x_new
    
    print("\nMax iterations reached")
    return x, history

# ------------------------------------------
# Run Algorithm
# ------------------------------------------

x0 = [1, 1]

solution, history = marquardt_method(x0)

print("\nOptimal Solution:", solution)
print("Minimum Value:", f(solution))

# ------------------------------------------
# Visualization (Contour + Path)
# ------------------------------------------

x_vals = np.linspace(-5, 5, 200)
y_vals = np.linspace(-5, 5, 200)

X, Y = np.meshgrid(x_vals, y_vals)
Z = X**2 + Y**2 + 3*X*Y + 4

plt.figure(figsize=(8,6))
plt.contour(X, Y, Z, levels=30)

# Plot path
history = np.array(history)
plt.plot(history[:,0], history[:,1], 'ro-', label="Path")

plt.scatter(solution[0], solution[1], color='blue', label='Minimum')

plt.title("Marquardt Method Optimization Path")
plt.xlabel("x1")
plt.ylabel("x2")
plt.legend()
plt.grid()
plt.show()
