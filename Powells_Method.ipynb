import numpy as np
import matplotlib.pyplot as plt

# Objective function
def f(x):
    return (x[0] - 2)**2 + (x[1] - 1)**2


# Golden Section Search (for line minimization)
def golden_section(phi, a, b, tol=1e-5):
    gr = (np.sqrt(5) - 1) / 2  # golden ratio

    c = b - gr * (b - a)
    d = a + gr * (b - a)

    while abs(b - a) > tol:
        if phi(c) < phi(d):
            b = d
        else:
            a = c

        c = b - gr * (b - a)
        d = a + gr * (b - a)

    return (a + b) / 2


# Powell's Method
def powell_method(x0, tol=1e-5, max_iter=100):
    n = len(x0)
    directions = np.eye(n)  # initial directions
    x = x0.copy()

    history = [x.copy()]

    for _ in range(max_iter):
        x_start = x.copy()

        for i in range(n):
            d = directions[i]

            # Line search function
            phi = lambda alpha: f(x + alpha * d)

            alpha = golden_section(phi, -2, 2)
            x = x + alpha * d

        # New direction
        new_dir = x - x_start

        # Replace first direction
        directions = np.roll(directions, -1, axis=0)
        directions[-1] = new_dir

        history.append(x.copy())

        # Convergence check
        if np.linalg.norm(x - x_start) < tol:
            break

    return x, np.array(history)


# Initial guess
x0 = np.array([0.0, 0.0])

# Run Powell method
solution, history = powell_method(x0)

print("Optimal Solution:", solution)


# ========================
# 📊 Plotting
# ========================

# Create grid
x_vals = np.linspace(-1, 4, 100)
y_vals = np.linspace(-1, 4, 100)
X, Y = np.meshgrid(x_vals, y_vals)
Z = (X - 2)**2 + (Y - 1)**2

# Plot contours
plt.figure(figsize=(8,6))
plt.contour(X, Y, Z, levels=20)

# Plot optimization path
plt.plot(history[:,0], history[:,1], 'ro-', label="Path")

# Mark solution
plt.scatter(solution[0], solution[1], color='blue', label="Minimum")

plt.title("Powell's Method Optimization Path")
plt.xlabel("x")
plt.ylabel("y")
plt.legend()
plt.grid()
plt.show()
