import numpy as np
import matplotlib.pyplot as plt

def golden_section_search(f, a, b, tol=1e-5, max_iter=100):
    """
    Golden Section Search to find minimum of function f in [a, b]
    """

    phi = (1 + np.sqrt(5)) / 2   # Golden ratio
    resphi = 2 - phi             # ≈ 0.382

    # Initial interior points
    x1 = a + resphi * (b - a)
    x2 = b - resphi * (b - a)

    f1 = f(x1)
    f2 = f(x2)

    history = []

    for i in range(max_iter):
        history.append((i, a, b, x1, x2, f1, f2))

        # Stopping condition
        if abs(b - a) < tol:
            break

        if f1 < f2:
            b = x2
            x2 = x1
            f2 = f1
            x1 = a + resphi * (b - a)
            f1 = f(x1)
        else:
            a = x1
            x1 = x2
            f1 = f2
            x2 = b - resphi * (b - a)
            f2 = f(x2)

    x_min = (a + b) / 2
    f_min = f(x_min)

    return x_min, f_min, history


# -------------------------------
# Example Function (CHANGE THIS)
# -------------------------------
def f(x):
    return (x - 2)**2 + 1


# -------------------------------
# Run the Algorithm
# -------------------------------
a, b = 0, 5

x_min, f_min, history = golden_section_search(f, a, b)

print("Minimum found at x =", x_min)
print("Minimum function value =", f_min)


# -------------------------------
# Plotting
# -------------------------------
x_vals = np.linspace(a, b, 200)
y_vals = f(x_vals)

plt.figure(figsize=(8, 5))
plt.plot(x_vals, y_vals, label="f(x)")
plt.scatter(x_min, f_min, color='red', zorder=5, label="Minimum")
plt.title("Golden Section Search Method")
plt.xlabel("x")
plt.ylabel("f(x)")
plt.legend()
plt.grid()
plt.show()


# -------------------------------
# Iteration Table (Optional)
# -------------------------------
print("\nIteration Details:")
print("Iter |     a     |     b     |    x1     |    x2     |   f(x1)   |   f(x2)")
for row in history:
    i, a_i, b_i, x1_i, x2_i, f1_i, f2_i = row
    print(f"{i:4d} | {a_i:.5f} | {b_i:.5f} | {x1_i:.5f} | {x2_i:.5f} | {f1_i:.5f} | {f2_i:.5f}")
