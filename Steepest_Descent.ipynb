import numpy as np
import matplotlib.pyplot as plt

# Objective function
def f(x):
    return x[0]**2 + x[1]**2 + 2*x[0]*x[1] + 3  # convex quadratic

# Gradient of function
def grad_f(x):
    return np.array([
        2*x[0] + 2*x[1],
        2*x[1] + 2*x[0]
    ])

# Backtracking line search
def line_search(x, d, alpha=1.0, rho=0.5, c=1e-4):
    while f(x + alpha*d) > f(x) + c*alpha*np.dot(grad_f(x), d):
        alpha *= rho
    return alpha

# Steepest Descent Method
def steepest_descent(x0, tol=1e-6, max_iter=100):
    x = x0
    path = [x.copy()]
    
    for i in range(max_iter):
        grad = grad_f(x)
        
        if np.linalg.norm(grad) < tol:
            break
        
        d = -grad
        alpha = line_search(x, d)
        
        x = x + alpha * d
        path.append(x.copy())
    
    return x, np.array(path)

# Initial point
x0 = np.array([3.0, -2.0])

# Run algorithm
solution, path = steepest_descent(x0)

print("Optimal Solution:", solution)
print("Optimal Value:", f(solution))

# ------------------ Plotting ------------------

x_vals = np.linspace(-5, 5, 100)
y_vals = np.linspace(-5, 5, 100)
X, Y = np.meshgrid(x_vals, y_vals)
Z = X**2 + Y**2 + 2*X*Y + 3

plt.figure(figsize=(8,6))
plt.contour(X, Y, Z, levels=30)

# Plot path
plt.plot(path[:,0], path[:,1], 'ro-', label='Descent Path')

plt.title("Steepest Descent Method")
plt.xlabel("x1")
plt.ylabel("x2")
plt.legend()
plt.grid()
plt.show()
