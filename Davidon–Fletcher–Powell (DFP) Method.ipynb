import numpy as np

# -------------------------------
# Objective Function
# Example: f(x, y) = x^2 + y^2 + xy
# -------------------------------
def f(x):
    return x[0]**2 + x[1]**2 + x[0]*x[1]

# Gradient of f
def grad_f(x):
    return np.array([
        2*x[0] + x[1],
        2*x[1] + x[0]
    ])

# -------------------------------
# Line Search (Backtracking)
# -------------------------------
def line_search(f, grad_f, x, d, alpha=1, rho=0.5, c=1e-4):
    while f(x + alpha*d) > f(x) + c*alpha*np.dot(grad_f(x), d):
        alpha *= rho
    return alpha

# -------------------------------
# DFP Method
# -------------------------------
def dfp_method(f, grad_f, x0, tol=1e-6, max_iter=100):
    n = len(x0)
    x = x0.copy()
    
    H = np.eye(n)  # Initial inverse Hessian approximation
    
    for k in range(max_iter):
        g = grad_f(x)
        
        # Stopping condition
        if np.linalg.norm(g) < tol:
            break
        
        # Search direction
        d = -np.dot(H, g)
        
        # Line search
        alpha = line_search(f, grad_f, x, d)
        
        # Update x
        x_new = x + alpha * d
        
        # Compute s and y
        s = x_new - x
        y = grad_f(x_new) - g
        
        # DFP Update
        sy = np.dot(s, y)
        if sy == 0:
            break
        
        term1 = np.outer(s, s) / sy
        term2 = np.dot(H, np.outer(y, y)).dot(H) / np.dot(y, np.dot(H, y))
        
        H = H + term1 - term2
        
        x = x_new
        
        print(f"Iteration {k+1}: x = {x}, f(x) = {f(x)}")
    
    return x

# -------------------------------
# Run Example
# -------------------------------
x0 = np.array([5.0, 5.0])
solution = dfp_method(f, grad_f, x0)

print("\nOptimal Solution:", solution)
print("Minimum Value:", f(solution))
