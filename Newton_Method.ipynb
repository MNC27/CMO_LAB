import numpy as np

# -----------------------------
# Define function, gradient, Hessian
# -----------------------------

def f(x):
    return x[0]**2 + x[1]**2 + 3*x[0]*x[1] + 4

def grad_f(x):
    return np.array([
        2*x[0] + 3*x[1],
        2*x[1] + 3*x[0]
    ])

def hessian_f(x):
    return np.array([
        [2, 3],
        [3, 2]
    ])

# -----------------------------
# Newton's Method
# -----------------------------

def newton_method(x0, tol=1e-6, max_iter=100):
    x = np.array(x0, dtype=float)
    
    for i in range(max_iter):
        grad = grad_f(x)
        hess = hessian_f(x)
        
        # Solve H * p = grad
        p = np.linalg.solve(hess, grad)
        
        x_new = x - p
        
        print(f"Iter {i+1}: x = {x_new}, f(x) = {f(x_new)}")
        
        # Convergence check
        if np.linalg.norm(x_new - x) < tol:
            print("\nConverged!")
            return x_new
        
        x = x_new
    
    return x

# -----------------------------
# Initial guess
# -----------------------------

x0 = [1, 1]

# Run Newton Method
solution = newton_method(x0)

print("\nOptimal solution:", solution)
print("Minimum value:", f(solution))
