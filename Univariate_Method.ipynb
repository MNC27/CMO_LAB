import numpy as np
import matplotlib.pyplot as plt

# -------------------------------
# Golden Section Search (1D)
# -------------------------------
def golden_section(f, a, b, tol=1e-5):
    phi = (1 + np.sqrt(5)) / 2
    resphi = 2 - phi

    x1 = a + resphi * (b - a)
    x2 = b - resphi * (b - a)

    f1 = f(x1)
    f2 = f(x2)

    while abs(b - a) > tol:
        if f1 < f2:
            b = x2
            x2 = x1
            f2 = f1
            x1 = a + resphi * (b - a)
            f1 = f(x1)
        else:
            a = x1
            x1 = x2
            f1 = f2
            x2 = b - resphi * (b - a)
            f2 = f(x2)

    return (a + b) / 2


# -------------------------------
# Univariate Method
# -------------------------------
def univariate_method(f, x0, bounds, tol=1e-5, max_iter=50):
    x = np.array(x0, dtype=float)
    n = len(x)

    path = [x.copy()]

    for k in range(max_iter):
        x_old = x.copy()

        for i in range(n):
            def f1d(xi):
                temp = x.copy()
                temp[i] = xi
                return f(temp)

            a, b = bounds[i]
            x[i] = golden_section(f1d, a, b, tol)

            path.append(x.copy())

        if np.linalg.norm(x - x_old) < tol:
            break

    return x, f(x), np.array(path)


# -------------------------------
# Example Function (2D)
# -------------------------------
def f(X):
    x, y = X
    return (x - 2)**2 + (y - 3)**2


# -------------------------------
# Run Algorithm
# -------------------------------
x0 = [0, 0]
bounds = [(-5, 5), (-5, 5)]

x_opt, f_opt, path = univariate_method(f, x0, bounds)

print("Optimal point:", x_opt)
print("Minimum value:", f_opt)


# -------------------------------
# Plot Contour + Path
# -------------------------------
x_vals = np.linspace(-1, 5, 100)
y_vals = np.linspace(-1, 6, 100)

X, Y = np.meshgrid(x_vals, y_vals)
Z = (X - 2)**2 + (Y - 3)**2

plt.figure(figsize=(8, 6))

# Contour plot
plt.contour(X, Y, Z, levels=20)

# Path (zig-zag)
path = np.array(path)
plt.plot(path[:, 0], path[:, 1], 'ro-', label="Path")

# Start and End points
plt.scatter(path[0, 0], path[0, 1], color='green', label="Start")
plt.scatter(x_opt[0], x_opt[1], color='blue', label="Minimum")

plt.title("Univariate Method (Coordinate Descent)")
plt.xlabel("x")
plt.ylabel("y")
plt.legend()
plt.grid()
plt.show()
